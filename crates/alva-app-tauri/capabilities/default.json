{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window: core IPC, events, window controls, dialog.",
  "windows": ["main", "inspector"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "dialog:default"
  ]
}
