{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alva Agent",
  "version": "0.1.0",
  "identifier": "com.alva.agent",
  "build": {
    "frontendDist": "web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix web run dev",
    "beforeBuildCommand": "npm --prefix web run build"
  },
  "app": {
    "windows": [
      {
        "title": "Alva Agent",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
