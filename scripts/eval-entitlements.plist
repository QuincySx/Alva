<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Outbound network client. The only entitlement that adhoc /
         self-signed certs can carry without breaking the signature.
         Anything under `com.apple.developer.*` requires an Apple
         Developer Program cert to inject, and trying to do so leaves
         the binary with a malformed signature → Gatekeeper SIGKILL. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
