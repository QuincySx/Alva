<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Outbound network client (used when sandboxed; harmless otherwise). -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Outbound multicast/broadcast — sometimes required for Local Network
         Privacy to register the binary as a valid network actor. -->
    <key>com.apple.developer.networking.multicast</key>
    <true/>
</dict>
</plist>
